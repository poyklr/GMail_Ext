{
  "manifest_version": 3,
  "name": "Copilot Review → Linear",
  "version": "1.0.0",
  "description": "Create Linear tickets from GitHub Copilot review emails in Gmail",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://api.linear.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Create Linear Ticket"
  }
}
